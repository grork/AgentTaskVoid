{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event sessionStart",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event userPromptSubmitted",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event preToolUse",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event postToolUse",
        "timeoutSec": 10
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event postToolUseFailure",
        "timeoutSec": 10
      }
    ],
    "permissionRequest": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event permissionRequest",
        "timeoutSec": 10
      }
    ],
    "notification": [
      {
        "type": "command",
