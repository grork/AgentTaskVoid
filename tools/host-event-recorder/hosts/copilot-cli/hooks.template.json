        "timeoutSec": 10
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event subagentStop",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "powershell": "& '__RECORDER_EXE_PATH__' --host copilot-cli --event errorOccurred",
        "timeoutSec": 10
      }
