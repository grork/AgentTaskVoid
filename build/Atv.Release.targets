<?xml version="1.0" encoding="utf-8"?>
<!--
  Atv.Release.targets

  Phase 12 (release packaging). DIST-1/DIST-7/DIST-8: a single command producing
  signed full-MSIX release artifacts for BOTH win-x64 and win-arm64 from a clean
  tree, using a throwaway self-signed DEV certificate. Real-cert acquisition and
  winget submission stay deferred (DIST-2) - this pipeline proves the mechanics.

  Usage (from repo root): `dotnet build src\Atv\Atv.csproj -t:AtvRelease`
  (or the two per-arch targets individually: -t:AtvReleaseWinX64 / -t:AtvReleaseWinArm64).

  Produces (repo-root-relative, all gitignored under artifacts\):
    artifacts\release\cert\devcert.pfx / .cer   (self-signed; NOT trusted by this
                                                   target - trusting a machine's
                                                   cert store needs admin, a
                                                   separate SUPERVISED step, see
                                                   docs\release.md)
    artifacts\release\publish\win-x64\...       (NativeAOT publish output)
    artifacts\release\publish\win-arm64\...
    artifacts\release\msix\Codevoid.AgentTaskVoid_<ver>_x64.msix     (signed)
    artifacts\release\msix\Codevoid.AgentTaskVoid_<ver>_arm64.msix   (signed)

  Orchestration is out-of-process Exec (dotnet publish / winapp package /
  winapp sign) - the same idiom build/Atv.Package.targets documents ("an
  orchestrating target Execs winapp", DIST-7). Each per-arch target carries
  explicit Inputs/Outputs so MSBuild's own target skip-detection makes a
  re-run with no source/manifest/cert changes a no-op repack (AC1) - winapp
  itself is not asked to do any incremental work.

  Both publishes need the matching Visual Studio VC build tools component
  installed (VC.Tools.x86.x64 for win-x64, VC.Tools.ARM64 for win-arm64).
  ILCompiler's findvcvarsall.bat finds them through vswhere.exe at a fixed
  path under the VS Installer directory, so there is nothing for this target
  or the invoking session to put on PATH - see CLAUDE.md's NativeAOT section.

  Manifest consumption: explicit winapp "manifest" flag pointed at the phase-01
  stamped obj\ copy, PER RID (DIST-7 - never auto-detect). That file is produced as a
  side effect of the nested `dotnet publish -r <rid> -c Release` Exec
  (AtvStampAppxManifest is BeforeTargets="Build", and Publish runs Build
  first), so it already exists on disk by the time `winapp package` runs.

  Publisher (`CN=AppTaskInfoCli`) is DIST-7's static, deliberately NOT
  brand-parameterized field - the same literal hand-authored in
  Package\AppxManifest.template.xml. Repeated here (not read from Branding.cs)
  because invariant #2 covers the BRAND, and DIST-7 explicitly settled
  Publisher as an intentionally unparameterized field; the dev cert's subject
  must match the manifest's Identity/@Publisher exactly for the package to be
  installable once trusted.

  ===================================================================================
  DIST-3 amendment (2026-07-10): build-kind-aware identity, and the -reltest variant
  ===================================================================================
  Every nested `dotnet publish` Exec below passes $(_AtvReleaseIdentityFlags) so the
  nested build's OWN evaluation of build/Atv.Package.targets' AtvStampAppxManifest
  sees AtvReleaseIdentity=true (a clean, pathhash-free Name = $(AtvBrandName),
  alias "atv") - a shipped identity must not encode this dev box's build-directory
  path. Passing -p: on the nested `dotnet publish` command line is required (not
  optional): that publish runs as a genuinely SEPARATE process/MSBuild evaluation,
  which does not otherwise inherit this outer build's properties.

  Building the THROWAWAY smoke variant - the one this file's own header calls "a
  release-on-dev-box smoke install that must coexist with the dev pool" - is
  `dotnet build src\Atv\Atv.csproj -t:AtvRelease -p:AtvVerifyIdentity=true`:
  $(AtvVerifyIdentity) here (the OUTER build's property, read directly, since it is
  supplied on this same command line) additionally threads -p:AtvVerifyIdentity=true
  into the nested publish, which resolves to Name=$(AtvBrandName)-reltest,
  alias "atv-reltest" (AtvStampAppxManifest's own build-kind branching gives verify
  priority over release when both flags are set). The resulting artifacts land under
  a DISTINCT filename (see $(_AtvMsixWinX64)/$(_AtvMsixWinArm64) below) so they never
  collide with, or falsely satisfy the Inputs/Outputs skip-detection of, the real
  release msix - the two builds are otherwise identical (same publish output, same
  throwaway dev cert; only the packaged manifest's Name/alias differ).
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <_AtvReleaseRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\artifacts\release'))</_AtvReleaseRoot>
    <_AtvReleasePublisher>CN=AppTaskInfoCli</_AtvReleasePublisher>
    <_AtvCertDir>$(_AtvReleaseRoot)\cert</_AtvCertDir>
    <_AtvCertPfx>$(_AtvCertDir)\devcert.pfx</_AtvCertPfx>
    <_AtvCertPassword>password</_AtvCertPassword>
    <_AtvMsixDir>$(_AtvReleaseRoot)\msix</_AtvMsixDir>

    <!--
      Threaded into every nested `dotnet publish` Exec below (DIST-3 amendment): the
      real release build always stamps the clean release identity;
      -p:AtvVerifyIdentity=true (outer build property, e.g.
      `-t:AtvRelease -p:AtvVerifyIdentity=true`) additionally requests the distinct
      "-reltest" throwaway smoke identity instead (AtvStampAppxManifest gives it
      priority over AtvReleaseIdentity when both are set).
    -->
    <_AtvReleaseIdentityFlags>-p:AtvReleaseIdentity=true</_AtvReleaseIdentityFlags>
    <_AtvReleaseIdentityFlags Condition="'$(AtvVerifyIdentity)' == 'true'">-p:AtvReleaseIdentity=true -p:AtvVerifyIdentity=true</_AtvReleaseIdentityFlags>

    <!-- Filename suffix distinguishing the -reltest smoke artifact from the real release msix (see the header comment above). -->
    <_AtvMsixNameSuffix Condition="'$(AtvVerifyIdentity)' == 'true'">_reltest</_AtvMsixNameSuffix>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Static (evaluation-time) source globs feeding every per-arch target's
      Inputs. MUST stay top-level (not target-scoped): MSBuild resolves a
      Target's Inputs/Outputs strings BEFORE any task runs, so an item that
      is itself only populated by an earlier target would be empty at the
      moment it matters.
    -->
    <AtvReleaseSourceFiles Include="$(MSBuildProjectDirectory)\**\*.cs" Exclude="$(MSBuildProjectDirectory)\obj\**;$(MSBuildProjectDirectory)\bin\**" />
    <AtvReleaseSourceFiles Include="$(MSBuildProjectDirectory)\..\Atv.IconRendering\**\*.cs" Exclude="$(MSBuildProjectDirectory)\..\Atv.IconRendering\obj\**;$(MSBuildProjectDirectory)\..\Atv.IconRendering\bin\**" />
    <AtvReleaseSourceFiles Include="$(AtvManifestTemplate)" />
    <AtvReleaseSourceFiles Include="$(MSBuildProjectDirectory)\Package\Assets\**" />
    <AtvReleaseSourceFiles Include="$(MSBuildThisFileFullPath)" />
  </ItemGroup>

  <!-- ==================== dev cert (shared by both arches) ==================== -->

  <Target Name="AtvReleaseCert" Inputs="$(MSBuildThisFileFullPath)" Outputs="$(_AtvCertPfx)">
    <MakeDir Directories="$(_AtvCertDir)" Condition="!Exists('$(_AtvCertDir)')" />
    <Exec Command="winapp cert generate --publisher &quot;$(_AtvReleasePublisher)&quot; --output &quot;$(_AtvCertPfx)&quot; --password &quot;$(_AtvCertPassword)&quot; --export-cer --if-exists Skip" />
    <Message Importance="high" Text="[Atv.Release] Dev cert ready: $(_AtvCertPfx) (self-signed, publisher $(_AtvReleasePublisher); NOT trusted anywhere - see docs/release.md for the supervised trust step)." />
  </Target>

  <!-- ==================== version-dependent output paths ==================== -->
  <!--
    NBGV's $(BuildVersion) is an OUTPUT of GetBuildVersion, unknown at file-
    evaluation time (same trap build/Atv.Package.targets documents at length)
    - so the msix filenames that embed it are computed inside a target that
    DependsOnTargets="GetBuildVersion", never in a file-body PropertyGroup.
    Because MSBuild fully runs a target's DependsOnTargets chain before
    evaluating that target's OWN Inputs/Outputs, AtvReleaseWinX64/Arm64 below
    can safely reference $(_AtvMsixWinX64)/$(_AtvMsixWinArm64) in their
    Outputs attribute: by the time those are evaluated, this target (a
    dependency of both) has already run and set them as ordinary (global)
    MSBuild properties.
  -->
  <Target Name="AtvReleaseComputeVersion" DependsOnTargets="GetBuildVersion">
    <PropertyGroup>
      <!-- $(_AtvMsixNameSuffix) is "_reltest" under -p:AtvVerifyIdentity=true, empty otherwise (see the header comment / top PropertyGroup) - keeps the smoke artifact from ever colliding with, or falsely up-to-date-skipping against, the real release msix. -->
      <_AtvMsixWinX64>$(_AtvMsixDir)\$(AtvBrandName)_$(BuildVersion)_x64$(_AtvMsixNameSuffix).msix</_AtvMsixWinX64>
      <_AtvMsixWinArm64>$(_AtvMsixDir)\$(AtvBrandName)_$(BuildVersion)_arm64$(_AtvMsixNameSuffix).msix</_AtvMsixWinArm64>
    </PropertyGroup>
  </Target>

  <!-- ==================== win-x64 ==================== -->

  <PropertyGroup>
    <!--
      RID-qualified stamped-manifest path: mirrors Atv.csproj's own
      $(WinAppManifestPath) technique - built from $(BaseIntermediateOutputPath)
      and $(TargetFramework) literally (both evaluation-time-safe) plus a
      hardcoded "Release"/RID segment, rather than reading
      $(IntermediateOutputPath) itself (whose RID segment is only finalized at
      a nested build's OWN execution time - see build/Atv.Package.targets).
      "Release" is hardcoded (not $(Configuration)) because the nested publish
      Exec below always passes -c Release explicitly, regardless of whatever
      Configuration this outer `dotnet build -t:AtvRelease` happens to be
      evaluated under.
    -->
    <_AtvManifestWinX64>$(MSBuildProjectDirectory)\$(BaseIntermediateOutputPath)Release\$(TargetFramework)\win-x64\AppxManifest.xml</_AtvManifestWinX64>
    <_AtvPublishWinX64>$(_AtvReleaseRoot)\publish\win-x64</_AtvPublishWinX64>
  </PropertyGroup>

  <Target Name="AtvReleaseWinX64"
          DependsOnTargets="AtvReleaseComputeVersion;AtvReleaseCert"
          Inputs="@(AtvReleaseSourceFiles);$(_AtvCertPfx)"
          Outputs="$(_AtvMsixWinX64)">

    <MakeDir Directories="$(_AtvMsixDir)" Condition="!Exists('$(_AtvMsixDir)')" />

    <Exec Command="dotnet publish &quot;$(MSBuildProjectDirectory)\Atv.csproj&quot; -r win-x64 -c Release -p:PublishAot=true $(_AtvReleaseIdentityFlags) -o &quot;$(_AtvPublishWinX64)&quot;" />

    <Error Condition="!Exists('$(_AtvManifestWinX64)')"
           Text="[Atv.Release] Expected stamped manifest not found: $(_AtvManifestWinX64) - the nested publish should have produced it via AtvStampAppxManifest." />

    <Exec Command="winapp package &quot;$(_AtvPublishWinX64)&quot; --manifest &quot;$(_AtvManifestWinX64)&quot; --output &quot;$(_AtvMsixWinX64)&quot;" />
    <Exec Command="winapp sign &quot;$(_AtvMsixWinX64)&quot; &quot;$(_AtvCertPfx)&quot; --password &quot;$(_AtvCertPassword)&quot;" />

    <Message Importance="high" Text="[Atv.Release] Signed: $(_AtvMsixWinX64)" />
  </Target>

  <!-- ==================== win-arm64 ==================== -->

  <PropertyGroup>
    <_AtvManifestWinArm64>$(MSBuildProjectDirectory)\$(BaseIntermediateOutputPath)Release\$(TargetFramework)\win-arm64\AppxManifest.xml</_AtvManifestWinArm64>
    <_AtvPublishWinArm64>$(_AtvReleaseRoot)\publish\win-arm64</_AtvPublishWinArm64>
  </PropertyGroup>

  <Target Name="AtvReleaseWinArm64"
          DependsOnTargets="AtvReleaseComputeVersion;AtvReleaseCert"
          Inputs="@(AtvReleaseSourceFiles);$(_AtvCertPfx)"
          Outputs="$(_AtvMsixWinArm64)">

    <MakeDir Directories="$(_AtvMsixDir)" Condition="!Exists('$(_AtvMsixDir)')" />

    <Exec Command="dotnet publish &quot;$(MSBuildProjectDirectory)\Atv.csproj&quot; -r win-arm64 -c Release -p:PublishAot=true $(_AtvReleaseIdentityFlags) -o &quot;$(_AtvPublishWinArm64)&quot;" />

    <Error Condition="!Exists('$(_AtvManifestWinArm64)')"
           Text="[Atv.Release] Expected stamped manifest not found: $(_AtvManifestWinArm64) - the nested publish should have produced it via AtvStampAppxManifest." />

    <Exec Command="winapp package &quot;$(_AtvPublishWinArm64)&quot; --manifest &quot;$(_AtvManifestWinArm64)&quot; --output &quot;$(_AtvMsixWinArm64)&quot;" />
    <Exec Command="winapp sign &quot;$(_AtvMsixWinArm64)&quot; &quot;$(_AtvCertPfx)&quot; --password &quot;$(_AtvCertPassword)&quot;" />

    <Message Importance="high" Text="[Atv.Release] Signed: $(_AtvMsixWinArm64)" />
  </Target>

  <!-- ==================== both, one command (AC1) ==================== -->

  <Target Name="AtvRelease" DependsOnTargets="AtvReleaseWinX64;AtvReleaseWinArm64">
    <Message Importance="high" Text="[Atv.Release] Both architectures packaged and signed under $(_AtvMsixDir)." />
  </Target>

</Project>
