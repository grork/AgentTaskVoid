<?xml version="1.0" encoding="utf-8"?>
<!--
  Atv.Package.targets

  DIST-7 ("The release full-package manifest"): stamps the AppxManifest template's
  build-varying fields into a RID-qualified obj/ copy:
    - Identity/@Name and the AppExecutionAlias's Alias - BUILD-KIND-AWARE as of the
      2026-07-10 DIST-3 amendment (see the big comment on AtvStampAppxManifest below).
    - Identity/@Version = NBGV's $(BuildVersion) (4-part numeric). $(Version) carries a
      semver+githash suffix that makeappx rejects against Identity/@Version: do not
      substitute it here.
    - The AppTaskProvider extension's Id - DIST-14 (2026-07-20): stamped with the SAME
      value as Identity/@Name (the template reuses the {IdentityName} token), because
      that extension Id turned out to be machine-global, not PFN-scoped (see the
      DIST-14 amendment on AtvStampAppxManifest below).
  Every other manifest field is static, hand-authored in the template itself.

  Consumption is out-of-process winapp, never an MSBuild import of the manifest:
    - Dev loop: Atv.csproj sets $(WinAppManifestPath) (evaluation-time, matching this
      target's execution-time-computed $(IntermediateOutputPath) for the no-RID case) so
      `winapp run` (via Microsoft.Windows.SDK.BuildTools.WinApp's dotnet-run interception)
      reads this obj/ copy directly.
    - Release packaging (phase 12) Execs `winapp package` with an explicit manifest
      flag pointed at this obj/ copy, against the RID-qualified copy produced by
      `dotnet publish -r <rid>`.

  Deliberately NOT gated by target-level Inputs/Outputs. NBGV's $(BuildVersion) can
  change build-to-build (git height) even though AppxManifest.template.xml itself never
  changes, so skipping this target based on the template's timestamp alone would let a
  stale Version survive indefinitely. Recomputing the (cheap) string replace on every
  Build/Publish and relying solely on WriteLinesToFile's WriteOnlyWhenDifferent to
  suppress no-op writes is what phase-01 AC3 actually tests: content-conditional, not
  timestamp-conditional.
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <AtvManifestTemplate>$(MSBuildProjectDirectory)\Package\AppxManifest.template.xml</AtvManifestTemplate>
  </PropertyGroup>

  <Target Name="AtvStampAppxManifest"
          BeforeTargets="Build"
          DependsOnTargets="GetBuildVersion">

    <Error Condition="!Exists('$(AtvManifestTemplate)')"
           Text="[Atv.Package] AppxManifest template not found at '$(AtvManifestTemplate)'." />
    <Error Condition="'$(AtvBrandName)' == ''"
           Text="[Atv.Package] AtvBrandName is empty - brand extraction from src/Atv/Branding.cs (Directory.Build.props) failed." />

    <!--
      ===============================================================================
      DIST-3 amendment (2026-07-10, ratified phase 12): build-kind-aware Name/alias.
      ===============================================================================
      The original mechanism (a single uniform Name = brand + path-hash, shared by
      dev-interactive AND the dev-cert release build) turned out NOT to isolate the
      two pools: a PFN's PublisherId is a hash of the declared Publisher STRING only
      (not the signing cert), and dev/release share the same static Publisher, so a
      uniform Name meant an IDENTICAL PFN for both - isolation leaned entirely on the
      still-deferred DIST-2 real-cert Publisher edit. Fix: vary Identity/@Name (and,
      since a shipped alias must not collide with a coexisting smoke install, the
      AppExecutionAlias too) by BUILD KIND, gated on two MSBuild properties that are
      false/empty by default and therefore invisible to the ordinary dev loop:

        - $(AtvReleaseIdentity)=true - set by build/Atv.Release.targets for the
          packaged build (`dotnet build ... -t:AtvRelease`). Stamps a CLEAN,
          pathhash-free Name = $(AtvBrandName) (e.g. "Codevoid.AgentTaskVoid") owning the bare
          "atv" alias. A shipped identity must never encode the developer's build
          directory path.
        - $(AtvVerifyIdentity)=true - set alongside AtvReleaseIdentity (see
          Atv.Release.targets' _AtvReleaseIdentityFlags) for the phase-12 throwaway
          smoke build (`-t:AtvRelease -p:AtvVerifyIdentity=true`). Stamps a DISTINCT
          Name = $(AtvBrandName)-reltest + alias "atv-reltest", so installing this
          on the SAME dev box as the dev-interactive pool cannot clobber its "atv"
          alias or share its PFN. Checked before AtvReleaseIdentity below so a verify
          build (which also sets AtvReleaseIdentity=true) gets the -reltest identity,
          not the clean release one.
          WARNING: only ever pass these flags via `-t:AtvRelease` (which publishes to
          artifacts/release/, RID-qualified). Passing -p:AtvVerifyIdentity=true (or
          -p:AtvReleaseIdentity=true) on a BARE `dotnet build` restamps the dev-loop
          obj/Debug manifest with the -reltest/clean identity and hijacks the next
          `dotnet run`/F5 until a plain rebuild restamps it back. The correct smoke
          command is `dotnet build src\Atv\Atv.csproj -t:AtvRelease -p:AtvVerifyIdentity=true`.
        - Neither set (the default - plain `dotnet build`/`dotnet run`/F5/`winapp run`)
          - Name = brand + a stable hash of the project directory, UNCHANGED from
          the original mechanism: the dev-interactive package this hash produces
          (`Codevoid.AgentTaskVoid-bbbb1168` in the primary worktree) is the identity that has
          already been driving real dogfooding (Checkpoint C1's taskbar render); it
          must keep resolving to the exact same Name after this change. The alias
          DID move (DIST-12, 2026-07-18, amending this DIST-3 amendment): dev now
          claims "atv-dev" instead of "atv", so the operator's daily card use can
          move onto the retail identity's "atv" without alias contention. See
          CLAUDE.md's "Package identity" section.

      Different Names -> different PFNs -> STRUCTURAL isolation of package STATE
      (app-data, tasks.json, the write mutex) between all three pools (release /
      dev-interactive / the reltest smoke), independent of Publisher (still static,
      "CN=AppTaskInfoCli", until the deferred DIST-2 real cert). The per-worktree
      TEST pool (build/Atv.TestIdentity.targets) is untouched by any of this - it
      stamps its own sibling template with its own "<brand>.Test.<hash>" Name +
      per-worktree alias, a rule DIST-7 already settled and this amendment does not
      relitigate.

      ===============================================================================
      DIST-14 amendment (2026-07-20): the AppTaskProvider extension Id needed the
      SAME treatment, separately - confirmed live.
      ===============================================================================
      PFN divergence isolates package STATE. It does NOT isolate Windows.UI.Shell.Tasks'
      AppTaskInfo provider registration: the host resolves that registration by the
      uap3:AppExtension Id ("com.microsoft.apptaskprovider") ALONE, machine-wide, not
      per-package. Established live, 2026-07-20, in this order: (1) a dev-interactive
      package alone, static extension Id - its cards render; (2) a second (retail)
      package registered alongside it, sharing that same static Id - the dev package's
      cards stopped rendering immediately, while it kept writing its own tasks.json and
      FindAll() kept returning its entries; (3) both packages re-registered with
      DISTINCT extension Ids - both rendered concurrently, two icons at once; (4) the
      execution alias used to launch a package was ruled out as the variable (atv.exe /
      atv-dev.exe / atv-test.exe each render fine when that package is the only one
      registered, regardless of alias). Microsoft's own docs describe this Id as
      scoped per-package (an entry-point discriminator within one app, not a
      cross-package key), not machine-global - this experimental provider's host
      diverges from that documented contract. See docs/windows-ui-shell-tasks/README.md
      for the full writeup.

      Fix: AppxManifest.template.xml's AppExtension Id is now the SAME {IdentityName}
      token as Identity/@Name, so the existing whole-file substitution stamps it
      build-kind-aware for free - $(_AtvIdentityName) below already IS the value; no
      second property, no second computation (standing invariant #2). The
      uap3:AppExtension Id has a hard 39-character platform limit, checked below.
    -->
    <PropertyGroup>
      <_AtvPathHash>$([MSBuild]::StableStringHash('$(MSBuildProjectDirectory)').ToString("x8"))</_AtvPathHash>

      <_AtvBuildKind Condition="'$(AtvVerifyIdentity)' == 'true'">verify</_AtvBuildKind>
      <_AtvBuildKind Condition="'$(_AtvBuildKind)' == '' And '$(AtvReleaseIdentity)' == 'true'">release</_AtvBuildKind>
      <_AtvBuildKind Condition="'$(_AtvBuildKind)' == ''">dev</_AtvBuildKind>

      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'verify'">$(AtvBrandName)-reltest</_AtvIdentityName>
      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'release'">$(AtvBrandName)</_AtvIdentityName>
      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'dev'">$(AtvBrandName)-$(_AtvPathHash)</_AtvIdentityName>

      <_AtvExecutionAlias Condition="'$(_AtvBuildKind)' == 'verify'">$(AtvCommandName)-reltest.exe</_AtvExecutionAlias>
      <_AtvExecutionAlias Condition="'$(_AtvBuildKind)' == 'dev'">$(AtvCommandName)-dev.exe</_AtvExecutionAlias>
      <_AtvExecutionAlias Condition="'$(_AtvBuildKind)' == 'release'">$(AtvCommandName).exe</_AtvExecutionAlias>

      <!--
        Execution-time only (DIST-7 implementation rule): $(BuildVersion) is an OUTPUT
        of NBGV's GetBuildVersionCore target, not known at file-evaluation time. And
        $(IntermediateOutputPath)'s RID segment (e.g. win-x64) is not finalized until
        the SDK's own RID-inference targets have already run; both are only safe to
        read here, inside this target's own execution-time PropertyGroup, never in a
        file-body (outside-target) PropertyGroup, where both would silently evaluate
        empty/unfinalized.
      -->
      <_AtvStampedManifestPath>$(IntermediateOutputPath)AppxManifest.xml</_AtvStampedManifestPath>
      <_AtvTemplateContent>$([System.IO.File]::ReadAllText('$(AtvManifestTemplate)'))</_AtvTemplateContent>
      <_AtvStampedContent>$(_AtvTemplateContent.Replace('{IdentityName}', '$(_AtvIdentityName)').Replace('{Version}', '$(BuildVersion)').Replace('{ExecutionAlias}', '$(_AtvExecutionAlias)'))</_AtvStampedContent>
    </PropertyGroup>

    <!--
      DIST-14: $(_AtvIdentityName) is stamped into the AppExtension Id (the
      AppTaskProvider) as well as Identity/@Name, and the AppExtension Id has a hard
      39-character platform limit that Identity/@Name itself does not. All four
      build-kind values are comfortably under it today; a future brand change could
      blow past it silently, so it's guarded - by AtvValidateStampedAppxManifest
      below, against the FILE this target actually writes, not against this property
      (a property-only guard here would be redundant with, and weaker than, that
      check - see its header comment).
    -->

    <MakeDir Directories="$(IntermediateOutputPath)" Condition="!Exists('$(IntermediateOutputPath)')" />

    <WriteLinesToFile
        File="$(_AtvStampedManifestPath)"
        Lines="$(_AtvStampedContent)"
        Overwrite="true"
        WriteOnlyWhenDifferent="true" />

    <Message Importance="high"
             Text="[Atv.Package] Stamped manifest: $(_AtvStampedManifestPath) (BuildKind=$(_AtvBuildKind), Identity Name=$(_AtvIdentityName), Alias=$(_AtvExecutionAlias), Version=$(BuildVersion))" />
  </Target>

  <!--
    Structural build-safety guard, not a test (DIST-14 - "AppTaskProvider extension Id
    must be build-kind-aware too"). A shared/misstamped AppExtension Id silently breaks
    taskbar rendering with no other symptom - cards persist, FindAll() still returns
    them, nothing draws - and that went unnoticed for a long, costly live-debugging
    session. Nothing else in the repo verifies the stamped manifest at all.

    Reads the manifest AtvStampAppxManifest just WROTE TO DISK (not the in-memory
    $(_AtvStampedContent) property that target built) and cross-checks it against the
    SAME execution-time properties that target computed -
    $(_AtvStampedManifestPath)/$(_AtvIdentityName)/$(_AtvExecutionAlias), reused as-is
    (standing invariant #2: no second computation of the identity name). Recomputing
    the expected values the stamper's own way and comparing properties-to-properties
    would be circular and prove nothing ("who watches the watchers"); reading the
    WRITTEN FILE instead catches what a property-only check cannot - a botched
    .Replace(), a renamed/typo'd token, a template edit that drops a substitution, or a
    stale file some other bug failed to rewrite.

    Runs AfterTargets="AtvStampAppxManifest" - every build (not just release), in the
    SAME MSBuild invocation that stamps.
  -->
  <Target Name="AtvValidateStampedAppxManifest" AfterTargets="AtvStampAppxManifest">
    <PropertyGroup>
      <_AtvWrittenManifest>$([System.IO.File]::ReadAllText('$(_AtvStampedManifestPath)'))</_AtvWrittenManifest>
      <_AtvWrittenIdentityName>$([System.Text.RegularExpressions.Regex]::Match($(_AtvWrittenManifest), 'Identity\s+Name="([^"]*)"').Groups[1].Value)</_AtvWrittenIdentityName>
      <_AtvWrittenAlias>$([System.Text.RegularExpressions.Regex]::Match($(_AtvWrittenManifest), 'ExecutionAlias\s+Alias="([^"]*)"').Groups[1].Value)</_AtvWrittenAlias>
      <_AtvWrittenExtensionId>$([System.Text.RegularExpressions.Regex]::Match($(_AtvWrittenManifest), 'com\.microsoft\.apptaskprovider"[\s\S]*?Id="([^"]*)"').Groups[1].Value)</_AtvWrittenExtensionId>
      <!-- Highest-value check: catches whole classes of template/token mistakes without enumerating them. Verified against both templates: every literal '{...}' in them is one of the known stamped tokens (in an attribute value or, in a couple of DIST-14 comment sentences, spelled out in prose) - the stamper's blunt whole-file .Replace() rewrites all such occurrences identically, so none survive a correct stamp. -->
      <_AtvWrittenPlaceholder>$([System.Text.RegularExpressions.Regex]::Match($(_AtvWrittenManifest), '\{[^}]*\}').Value)</_AtvWrittenPlaceholder>
    </PropertyGroup>

    <Error Condition="'$(_AtvWrittenIdentityName)' != '$(_AtvIdentityName)'"
           Text="[Atv.Package] Manifest validation failed for '$(_AtvStampedManifestPath)': Identity/@Name is '$(_AtvWrittenIdentityName)', expected '$(_AtvIdentityName)'." />

    <Error Condition="'$(_AtvWrittenAlias)' != '$(_AtvExecutionAlias)'"
           Text="[Atv.Package] Manifest validation failed for '$(_AtvStampedManifestPath)': ExecutionAlias/@Alias is '$(_AtvWrittenAlias)', expected '$(_AtvExecutionAlias)'." />

    <Error Condition="'$(_AtvWrittenExtensionId)' != '$(_AtvIdentityName)'"
           Text="[Atv.Package] Manifest validation failed for '$(_AtvStampedManifestPath)': AppTaskProvider AppExtension/@Id is '$(_AtvWrittenExtensionId)', expected '$(_AtvIdentityName)' (DIST-14 requires it to match Identity/@Name)." />

    <Error Condition="'$(_AtvWrittenPlaceholder)' != ''"
           Text="[Atv.Package] Manifest validation failed for '$(_AtvStampedManifestPath)': found an unsubstituted placeholder token '$(_AtvWrittenPlaceholder)' - a template edit or stamping change dropped a substitution." />

    <Error Condition="'$(_AtvWrittenExtensionId.Length)' &gt; '39'"
           Text="[Atv.Package] Manifest validation failed for '$(_AtvStampedManifestPath)': AppTaskProvider AppExtension/@Id '$(_AtvWrittenExtensionId)' is $(_AtvWrittenExtensionId.Length) characters - over the 39-character platform limit. Shorten AtvBrandName or the build-kind suffix." />
  </Target>

</Project>
