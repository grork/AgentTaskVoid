<?xml version="1.0" encoding="utf-8"?>
<!--
  Atv.Package.targets

  DIST-7 ("The release full-package manifest"): stamps the AppxManifest template's
  build-varying fields into a RID-qualified obj/ copy:
    - Identity/@Name and the AppExecutionAlias's Alias - BUILD-KIND-AWARE as of the
      2026-07-10 DIST-3 amendment (see the big comment on AtvStampAppxManifest below).
    - Identity/@Version = NBGV's $(BuildVersion) (4-part numeric). $(Version) carries a
      semver+githash suffix that makeappx rejects against Identity/@Version: do not
      substitute it here.
  Every other manifest field is static, hand-authored in the template itself.

  Consumption is out-of-process winapp, never an MSBuild import of the manifest:
    - Dev loop: Atv.csproj sets $(WinAppManifestPath) (evaluation-time, matching this
      target's execution-time-computed $(IntermediateOutputPath) for the no-RID case) so
      `winapp run` (via Microsoft.Windows.SDK.BuildTools.WinApp's dotnet-run interception)
      reads this obj/ copy directly.
    - Release packaging (phase 12) Execs `winapp package` with an explicit manifest
      flag pointed at this obj/ copy, against the RID-qualified copy produced by
      `dotnet publish -r <rid>`.

  Deliberately NOT gated by target-level Inputs/Outputs. NBGV's $(BuildVersion) can
  change build-to-build (git height) even though AppxManifest.template.xml itself never
  changes, so skipping this target based on the template's timestamp alone would let a
  stale Version survive indefinitely. Recomputing the (cheap) string replace on every
  Build/Publish and relying solely on WriteLinesToFile's WriteOnlyWhenDifferent to
  suppress no-op writes is what phase-01 AC3 actually tests: content-conditional, not
  timestamp-conditional.
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <AtvManifestTemplate>$(MSBuildProjectDirectory)\Package\AppxManifest.template.xml</AtvManifestTemplate>
  </PropertyGroup>

  <Target Name="AtvStampAppxManifest"
          BeforeTargets="Build"
          DependsOnTargets="GetBuildVersion">

    <Error Condition="!Exists('$(AtvManifestTemplate)')"
           Text="[Atv.Package] AppxManifest template not found at '$(AtvManifestTemplate)'." />
    <Error Condition="'$(AtvBrandName)' == ''"
           Text="[Atv.Package] AtvBrandName is empty - brand extraction from src/Atv/Branding.cs (Directory.Build.props) failed." />

    <!--
      ===============================================================================
      DIST-3 amendment (2026-07-10, ratified phase 12): build-kind-aware Name/alias.
      ===============================================================================
      The original mechanism (a single uniform Name = brand + path-hash, shared by
      dev-interactive AND the dev-cert release build) turned out NOT to isolate the
      two pools: a PFN's PublisherId is a hash of the declared Publisher STRING only
      (not the signing cert), and dev/release share the same static Publisher, so a
      uniform Name meant an IDENTICAL PFN for both - isolation leaned entirely on the
      still-deferred DIST-2 real-cert Publisher edit. Fix: vary Identity/@Name (and,
      since a shipped alias must not collide with a coexisting smoke install, the
      AppExecutionAlias too) by BUILD KIND, gated on two MSBuild properties that are
      false/empty by default and therefore invisible to the ordinary dev loop:

        - $(AtvReleaseIdentity)=true - set by build/Atv.Release.targets for the
          packaged build (`dotnet build ... -t:AtvRelease`). Stamps a CLEAN,
          pathhash-free Name = $(AtvBrandName) (e.g. "Agentaskvoid") owning the bare
          "atv" alias. A shipped identity must never encode the developer's build
          directory path.
        - $(AtvVerifyIdentity)=true - set alongside AtvReleaseIdentity (see
          Atv.Release.targets' _AtvReleaseIdentityFlags) for the phase-12 throwaway
          smoke build (`-t:AtvRelease -p:AtvVerifyIdentity=true`). Stamps a DISTINCT
          Name = $(AtvBrandName)-reltest + alias "atv-reltest", so installing this
          on the SAME dev box as the dev-interactive pool cannot clobber its "atv"
          alias or share its PFN. Checked before AtvReleaseIdentity below so a verify
          build (which also sets AtvReleaseIdentity=true) gets the -reltest identity,
          not the clean release one.
          WARNING: only ever pass these flags via `-t:AtvRelease` (which publishes to
          artifacts/release/, RID-qualified). Passing -p:AtvVerifyIdentity=true (or
          -p:AtvReleaseIdentity=true) on a BARE `dotnet build` restamps the dev-loop
          obj/Debug manifest with the -reltest/clean identity and hijacks the next
          `dotnet run`/F5 until a plain rebuild restamps it back. The correct smoke
          command is `dotnet build src\Atv\Atv.csproj -t:AtvRelease -p:AtvVerifyIdentity=true`.
        - Neither set (the default - plain `dotnet build`/`dotnet run`/F5/`winapp run`)
          - UNCHANGED from the original mechanism: Name = brand + a stable hash of
          the project directory, alias "atv". This is deliberate and load-bearing:
          the dev-interactive package this hash produces
          (`Agentaskvoid-bbbb1168` in the primary worktree) is the identity that has
          already been driving real dogfooding (Checkpoint C1's taskbar render); it
          must keep resolving to the exact same Name after this change.

      Different Names -> different PFNs -> STRUCTURAL isolation between all three
      pools (release / dev-interactive / the reltest smoke), independent of Publisher
      (still static, "CN=AppTaskInfoCli", until the deferred DIST-2 real cert). The
      per-worktree TEST pool (build/Atv.TestIdentity.targets) is untouched by any of
      this - it stamps its own sibling template with its own "<brand>.Test.<hash>"
      Name + per-worktree alias, a rule DIST-7 already settled and this amendment
      does not relitigate.
    -->
    <PropertyGroup>
      <_AtvPathHash>$([MSBuild]::StableStringHash('$(MSBuildProjectDirectory)').ToString("x8"))</_AtvPathHash>

      <_AtvBuildKind Condition="'$(AtvVerifyIdentity)' == 'true'">verify</_AtvBuildKind>
      <_AtvBuildKind Condition="'$(_AtvBuildKind)' == '' And '$(AtvReleaseIdentity)' == 'true'">release</_AtvBuildKind>
      <_AtvBuildKind Condition="'$(_AtvBuildKind)' == ''">dev</_AtvBuildKind>

      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'verify'">$(AtvBrandName)-reltest</_AtvIdentityName>
      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'release'">$(AtvBrandName)</_AtvIdentityName>
      <_AtvIdentityName Condition="'$(_AtvBuildKind)' == 'dev'">$(AtvBrandName)-$(_AtvPathHash)</_AtvIdentityName>

      <_AtvExecutionAlias Condition="'$(_AtvBuildKind)' == 'verify'">$(AtvCommandName)-reltest.exe</_AtvExecutionAlias>
      <_AtvExecutionAlias Condition="'$(_AtvBuildKind)' != 'verify'">$(AtvCommandName).exe</_AtvExecutionAlias>

      <!--
        Execution-time only (DIST-7 implementation rule): $(BuildVersion) is an OUTPUT
        of NBGV's GetBuildVersionCore target, not known at file-evaluation time. And
        $(IntermediateOutputPath)'s RID segment (e.g. win-x64) is not finalized until
        the SDK's own RID-inference targets have already run; both are only safe to
        read here, inside this target's own execution-time PropertyGroup, never in a
        file-body (outside-target) PropertyGroup, where both would silently evaluate
        empty/unfinalized.
      -->
      <_AtvStampedManifestPath>$(IntermediateOutputPath)AppxManifest.xml</_AtvStampedManifestPath>
      <_AtvTemplateContent>$([System.IO.File]::ReadAllText('$(AtvManifestTemplate)'))</_AtvTemplateContent>
      <_AtvStampedContent>$(_AtvTemplateContent.Replace('{IdentityName}', '$(_AtvIdentityName)').Replace('{Version}', '$(BuildVersion)').Replace('{ExecutionAlias}', '$(_AtvExecutionAlias)'))</_AtvStampedContent>
    </PropertyGroup>

    <MakeDir Directories="$(IntermediateOutputPath)" Condition="!Exists('$(IntermediateOutputPath)')" />

    <WriteLinesToFile
        File="$(_AtvStampedManifestPath)"
        Lines="$(_AtvStampedContent)"
        Overwrite="true"
        WriteOnlyWhenDifferent="true" />

    <Message Importance="high"
             Text="[Atv.Package] Stamped manifest: $(_AtvStampedManifestPath) (BuildKind=$(_AtvBuildKind), Identity Name=$(_AtvIdentityName), Alias=$(_AtvExecutionAlias), Version=$(BuildVersion))" />
  </Target>

</Project>
