<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest TEMPLATE for Agent Task Void (atv).
  See build/Atv.Package.targets and questions/distribution/DIST-7-release-full-package-manifest.md.

  The Identity element's Name and Version attributes, plus the AppExecutionAlias's
  Alias attribute below, are stamped at build time - via a plain token substitution,
  so this comment deliberately avoids spelling out those three token strings verbatim
  (build/Atv.Package.targets' replace is a blunt whole-file substitution and would
  rewrite them here too). Every other field below is static, hand-authored to match
  the ERGO-18 ("The shipped command name") brand decision: rename the brand there and
  update the literal strings here to match; DIST-7 explicitly settled that
  build-time-parameterizing every field is unneeded complexity.

  DIST-3's 2026-07-10 amendment made Name/alias stamping BUILD-KIND-AWARE (see
  build/Atv.Package.targets' AtvStampAppxManifest for the branching); DIST-12
  (2026-07-18) amends it again, moving the dev alias off `atv`: dev (default)
  keeps `<brand>-<pathhash>` + alias `atv-dev`; release stamps a clean
  pathhash-free `<brand>` + alias `atv` (the operator's daily card use); a
  throwaway "-reltest" smoke variant (`AtvVerifyIdentity=true`) stamps
  `<brand>-reltest` + alias `atv-reltest`, so a release-on-dev-box smoke
  install can coexist with the dev and retail pools without clobbering either
  alias. Different Names give each pool a structurally separate PFN and
  package state (app-data, tasks.json, mutex), independent of the still-static
  Publisher.

  DIST-14 (2026-07-20) stamps the AppTaskProvider extension's Id (below, in
  Applications/Application/Extensions) with the SAME per-build-kind value as
  Identity/@Name. The AppTaskInfo host resolves its provider registration by this
  Id ALONE, machine-wide, not per-package: two atv packages sharing the same
  static Id collided (one stopped rendering taskbar cards while still writing
  its own tasks.json - FindAll() kept returning its entries), and giving them
  distinct Ids fixed it - both rendered concurrently. Microsoft's own docs
  describe this Id as scoped per-package, not machine-global; this experimental
  provider's host diverges from that. See docs/windows-ui-shell-tasks/README.md
  for the full writeup and how this was established.

  This one template serves BOTH the dev loose-layout (`winapp run`, via the
  RID-unqualified obj/ copy) and the release pack (`winapp package`, via the
  RID-qualified obj/ copy, phase 12).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 uap5 desktop rescap">

  <Identity
    Name="{IdentityName}"
    Publisher="CN=AppTaskInfoCli"
    Version="{Version}" />

  <Properties>
    <DisplayName>Agent Task Void</DisplayName>
    <PublisherDisplayName>Codevoid</PublisherDisplayName>
    <Logo>Assets\Square44x44Logo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.26100.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
      Id="Atv"
      Executable="atv.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Agent Task Void"
        Description="Agent Task Void: agent task presence on the Windows 11 taskbar"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <!--
          Required for Windows.UI.Shell.Tasks.AppTaskInfo to function at all (not an
          identity-model detail; orthogonal to sparse vs full-package). PublicFolder
          must exist in the package layout; see Package/Public/.gitkeep.

          DIST-14: the AppTaskInfo host resolves its provider registration by this Id
          ALONE, machine-wide - established live with two atv packages registered at
          once: sharing a static, identical Id (as this element had before), one
          package stopped rendering tasks on the taskbar while it kept writing its own
          tasks.json and FindAll() kept returning its entries; giving the two packages
          distinct Ids fixed it, both rendering concurrently. Microsoft's docs
          describe this Id as scoped per-package (an entry-point discriminator within
          one app), not machine-global - this experimental provider's host diverges
          from that. Fix: reuse the SAME {IdentityName} token as Identity/@Name above
          (the blunt whole-file substitution already rewrites every occurrence), so
          the Id is build-kind-aware for free with no second computation (standing
          invariant #2). See docs/windows-ui-shell-tasks/README.md for the full
          writeup. The uap3:AppExtension Id has a hard 39-character platform limit;
          build/Atv.Package.targets guards it.
        -->
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension
            Name="com.microsoft.apptaskprovider"
            PublicFolder="Public"
            Id="{IdentityName}"
            DisplayName="AppTaskProvider for Agent Task Void" />
        </uap3:Extension>
        <!-- Puts the build-kind-aware alias on PATH (ERGO-18, DIST-7; DIST-12
             amends DIST-3 - `atv-dev` for dev, `atv` for release (the daily
             driver), `atv-reltest` for the phase-12 smoke variant; see
             build/Atv.Package.targets). -->
        <uap5:Extension Category="windows.appExecutionAlias">
          <uap5:AppExecutionAlias>
            <uap5:ExecutionAlias Alias="{ExecutionAlias}" />
          </uap5:AppExecutionAlias>
        </uap5:Extension>
        <!--
          Declared but DISABLED boot-recovery startup item (LIFE-20, "Logoff/reboot
          recovery"). The watchdog (phase 09) enables/disables this at runtime via
          Windows.ApplicationModel.StartupTask as it gains/clears live work; a no-op
          declaration until then.
        -->
        <desktop:Extension
          Category="windows.startupTask"
          Executable="atv.exe"
          EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask
            TaskId="CodevoidAgentTaskVoidBootRecovery"
            Enabled="false"
            DisplayName="Agent Task Void boot recovery" />
        </desktop:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
